# Database Configuration (Required)
# PostgreSQL database connection string
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"

# Direct database connection (for migrations)
DIRECT_URL="postgresql://user:password@host:port/database"

# Authentication (Required)
# Secret key for JWT token signing (generate with: openssl rand -hex 32)
JWT_SECRET="your-secret-key-here"

# NextAuth configuration URL (your deployment URL)
NEXTAUTH_URL="https://your-domain.com"

# Public Configuration (Required)
# Site URL accessible to users
NEXT_PUBLIC_SITE_URL="https://your-domain.com/"

# Default locale (zh-CN or en)
NEXT_PUBLIC_DEFAULT_LOCALE="zh-CN"

# File Storage (Optional)
# Local storage directory
UPLOAD_DIR="./uploads"

# Storage provider: local | s3 | r2 | supabase
STORAGE_PROVIDER="local"

# AWS S3 / Cloudflare R2 Configuration (Optional)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"
# AWS_BUCKET="your-bucket-name"

# Supabase Storage (Optional)
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_KEY="your-anon-key"
# SUPABASE_BUCKET="uploads"

# Email Service (Optional)
# Provider: console | smtp | sendgrid | resend | ses
EMAIL_PROVIDER="console"

# Default sender email
EMAIL_FROM="noreply@your-domain.com"

# SMTP Configuration (Optional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"

# SendGrid Configuration (Optional)
# SENDGRID_API_KEY="your-sendgrid-api-key"

# Resend Configuration (Optional)
# RESEND_API_KEY="your-resend-api-key"

# Payment Integration (Optional)
# Stripe Configuration
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# WeChat Pay Configuration (Optional)
# WECHAT_APP_ID="your-app-id"
# WECHAT_MCH_ID="your-merchant-id"
# WECHAT_API_KEY="your-api-key"

# Alipay Configuration (Optional)
# ALIPAY_APP_ID="your-app-id"
# ALIPAY_PRIVATE_KEY="your-private-key"
# ALIPAY_PUBLIC_KEY="alipay-public-key"

# Analytics & Monitoring (Optional)
# NODE_ENV="production"
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# SENTRY_DSN="your-sentry-dsn"

# Rate Limiting (Optional)
# RATE_LIMIT_MAX="100"
# RATE_LIMIT_WINDOW="900000"
